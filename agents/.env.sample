# =============================================================================
# game-agents — environment sample
# Copy to `.env` and fill in. Never commit your real `.env`.
#   cp .env.sample .env
# =============================================================================

# --- Credentials (required) --------------------------------------------------
# Anthropic API key used by the Claude Agent SDK. Get one at
# https://console.anthropic.com/ . The SDK / underlying Claude Code CLI reads
# ANTHROPIC_API_KEY from the environment.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: if you route through a gateway / proxy or Bedrock/Vertex, set the
# relevant variables instead of (or alongside) ANTHROPIC_API_KEY.
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1

# --- Model -------------------------------------------------------------------
# Full model ID the phases run on (ClaudeAgentOptions.model).
GAME_AGENT_MODEL=claude-opus-4-8
# Optional fallback if the primary is overloaded.
# GAME_AGENT_FALLBACK_MODEL=claude-sonnet-4-6

# --- Repository the agents operate on ----------------------------------------
# Defaults to the parent of this `agents/` dir (the game repo). Override when the
# checkout lives elsewhere (e.g. a mounted volume in Docker).
# GAME_REPO_ROOT=/home/reza/projects/game

# --- Run behavior ------------------------------------------------------------
# acceptEdits = autonomous (edits/bash without prompting) — needed for unattended
# n8n runs. Use "default" to require approval, or "plan" for a dry run.
GAME_AGENT_PERMISSION_MODE=acceptEdits

# Per-phase ceilings (safety rails for unattended loops).
GAME_AGENT_MAX_TURNS=60
# Optional hard cost cap per phase invocation, in USD. Unset = no cap.
# GAME_AGENT_MAX_BUDGET_USD=5.0

# --- HTTP server -------------------------------------------------------------
# n8n calls this server. Bind to 0.0.0.0 if n8n runs in another container.
GAME_AGENT_HOST=127.0.0.1
GAME_AGENT_PORT=8787
GAME_AGENT_RELOAD=false

# --- n8n side (for reference; set these in n8n, not here) --------------------
# The n8n workflows expect a base URL for this server, e.g.:
#   AGENT_SDK_BASE_URL=http://host.docker.internal:8787
