<?xml version="1.0" encoding="utf-8"?>
<!--
  Point the first source at the nupkgs bundled with YOUR Godot mono install:
    <dirname of the Godot binary>/GodotSharp/Tools/nupkgs
  This makes `dotnet build` work offline and pins the SDK to the editor version.
  nuget.org is kept second so external packages still restore online.
-->
<configuration>
  <packageSources>
    <add key="GodotBundled" value="/ABSOLUTE/PATH/TO/GodotSharp/Tools/nupkgs" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
